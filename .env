app = "ridex-backend"
primary_region = "sjc"

[build]
  dockerfile = "Dockerfile"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = false
  auto_start_machines = true
  [http_service.concurrency]
    type = "connections"
    hard_limit = 250
    soft_limit = 200

[[statics]]
  guest_path = "/app/staticfiles"
  url_prefix = "/static" 